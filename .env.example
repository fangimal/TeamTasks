# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=60s
SERVER_SHUTDOWN_TIMEOUT=5s

# MySQL database configuration
DATABASE_HOST=mysql
DATABASE_PORT=3306
DATABASE_USER=teamtasks
DATABASE_PASSWORD=teamtasks
DATABASE_NAME=teamtasks
DATABASE_ROOT_PASSWORD=root
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=5m

# Redis configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Logger configuration
LOGGER_LEVEL=info
LOGGER_FORMAT=json

# JWT authentication
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=24h

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# External email service (used for team invitations)
EMAIL_SERVICE_URL=https://httpbin.org/post
EMAIL_SERVICE_TIMEOUT=5s
